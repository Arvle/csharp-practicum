package main

import (
	"crypto/rand"
	"encoding/hex"
	"fmt"
)

func main() {
	// Generate a 64-byte (512-bit) secure random secret
	secret := make([]byte, 64)
	if _, err := rand.Read(secret); err != nil {
		fmt.Printf("Error generating secret: %v\n", err)
		return
	}
	
	fmt.Println("Generated JWT Secret:")
	fmt.Println(hex.EncodeToString(secret))
	fmt.Println("\nAdd this to your .env file as JWT_SECRET=<value>")
}
