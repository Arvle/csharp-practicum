# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=8080
ENV=development
API_NAME=C# Практикум API
API_VERSION=1.0.0
FRONTEND_URL=http://localhost:5173

# ============================================
# DATABASE CONFIGURATION
# ============================================
DATABASE_URL=postgres://postgres:postgres@localhost:5432/csharppracticum?sslmode=disable
DB_MAX_OPEN_CONNS=10
DB_MAX_IDLE_CONNS=5
AUTO_MIGRATE=true

# ============================================
# AUTHENTICATION & SECURITY
# ============================================
JWT_SECRET=change-this-secret-in-production
JWT_EXPIRATION_HOURS=24
TEACHER_ACCESS_CODE=change-this-code-in-production

# ============================================
# COMPILATION & CODE EXECUTION
# ============================================
COMPILATION_TIMEOUT_SECONDS=30
COMPRESS_LEVEL=5

# ============================================
# TIMEOUTS (в секундах)
# ============================================
REQUEST_TIMEOUT_SECONDS=60
READ_TIMEOUT_SECONDS=15
WRITE_TIMEOUT_SECONDS=15
IDLE_TIMEOUT_SECONDS=60

# ============================================
# CORS
# ============================================
ALLOWED_ORIGINS=["http://localhost:5173", "http://127.0.0.1:5173"]
ALLOWED_METHODS=["GET", "POST", "PUT", "DELETE", "OPTIONS"]
ALLOWED_HEADERS=["Accept", "Authorization", "Content-Type", "X-CSRF-Token"]
EXPOSED_HEADERS=["Link"]
CORS_MAX_AGE=300

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
LOG_FORMAT=text

# ============================================
# DEVELOPMENT
# ============================================
SEED_ENABLED=false
DEBUG_SQL=false